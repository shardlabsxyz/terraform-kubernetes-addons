{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    ":separateMajorReleases",
    ":ignoreUnstable",
    ":prImmediately",
    ":updateNotScheduled",
    ":disableRateLimiting",
    ":ignoreModulesAndTests",
    ":gitSignOff",
    "group:monorepos",
    "group:recommended",
    "helpers:disableTypesNodeMajor",
    "workarounds:all",
    ":dependencyDashboard",
    "helpers:pinGitHubActionDigests"
  ],
  "baseBranchPatterns": [
    "main"
  ],
  "enabledManagers": [
    "helmv3",
    "github-actions",
    "mise",
    "pre-commit",
    "terraform"
  ],
  "semanticCommits": "enabled",
  "automerge": false,
  "platformAutomerge": false,
  "rebaseWhen": "behind-base-branch",
  "helmv3": {
    "enabled": true,
    "managerFilePatterns": [
      "/(^|/)helm-dependencies.yaml$/"
    ]
  },
  "pre-commit": {
    "enabled": true
  },
  "commitMessageExtra": "to {{newVersion}} (was {{currentVersion}})",
  "prHourlyLimit": 0,
  "packageRules": [
    {
      "description": "Label major updates",
      "matchUpdateTypes": [
        "major"
      ],
      "addLabels": [
        "update-major",
        "breaking-change"
      ]
    },
    {
      "description": "Label minor updates",
      "matchUpdateTypes": [
        "minor"
      ],
      "addLabels": [
        "update-minor"
      ]
    },
    {
      "description": "Label patch updates",
      "matchUpdateTypes": [
        "patch"
      ],
      "addLabels": [
        "update-patch"
      ]
    },
    {
      "description": "Label digest pinning and digest refreshes",
      "matchUpdateTypes": [
        "digest",
        "pinDigest"
      ],
      "addLabels": [
        "update-digest"
      ]
    },
    {
      "matchManagers": [
        "github-actions"
      ],
      "semanticCommitScope": "ci",
      "semanticCommitType": "chore"
    },
    {
      "matchManagers": [
        "mise",
        "pre-commit"
      ],
      "semanticCommitScope": "ci",
      "semanticCommitType": "chore"
    },
    {
      "matchManagers": [
        "helmv3"
      ],
      "semanticCommitScope": "charts",
      "semanticCommitType": "fix",
      "matchUpdateTypes": [
        "patch",
        "digest"
      ]
    },
    {
      "matchManagers": [
        "helmv3"
      ],
      "semanticCommitScope": "charts",
      "semanticCommitType": "feat",
      "matchUpdateTypes": [
        "major",
        "minor"
      ]
    },
    {
      "description": "Only low-risk automation updates are eligible for Mergify automerge",
      "matchManagers": [
        "helmv3",
        "github-actions",
        "mise",
        "pre-commit"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch",
        "digest"
      ],
      "addLabels": [
        "automerge-candidate"
      ]
    },
    {
      "matchManagers": [
        "terraform"
      ],
      "semanticCommitScope": "tf",
      "semanticCommitType": "feat",
      "automerge": false
    }
  ]
}
